{
    "buildCommand": "npm run build",
    "outputDirectory": "build",
    "framework": "create-react-app",
    "build": {
        "env": {
            "NODE_OPTIONS": "--openssl-legacy-provider",
            "CI": "false"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://chatflow-saqib.onrender.com/api/:path*"
        },
        {
            "source": "/socket.io/:path*",
            "destination": "https://chatflow-saqib.onrender.com/socket.io/:path*"
        }
    ]
}